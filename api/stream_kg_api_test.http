@baseUrl = http://127.0.0.1:5001
@json = application/json

###
# 0) Health check
GET {{baseUrl}}/health

###
# 1) Init constraints
POST {{baseUrl}}/init

###
# 2) /event - customer_update (first insert)
POST {{baseUrl}}/event
Content-Type: {{json}}

{
  "type": "customer_update",
  "ts": "2025-04-02T17:17:05",
  "data": {
    "baseid": "uid_1001",
    "identity_no": "identity_hash_1001_a",
    "mobile_phone": "phone_hash_1001_a"
  }
}

###
# 3) /event - customer_update (same identity+phone, should dedupe)
POST {{baseUrl}}/event
Content-Type: {{json}}

{
  "type": "customer_update",
  "ts": "2025-04-02T17:18:05",
  "data": {
    "baseid": "uid_1001",
    "identity_no": "identity_hash_1001_a",
    "mobile_phone": "phone_hash_1001_a"
  }
}

###
# 4) /event - customer_update (identity changed, should update)
POST {{baseUrl}}/event
Content-Type: {{json}}

{
  "type": "customer_update",
  "ts": "2025-04-02T17:19:05",
  "data": {
    "baseid": "uid_1001",
    "identity_no": "identity_hash_1001_b",
    "mobile_phone": "phone_hash_1001_a"
  }
}

###
# 5) /event - login (full fields)
POST {{baseUrl}}/event
Content-Type: {{json}}

{
  "type": "login",
  "ts": "2025-04-02T17:20:56",
  "data": {
    "phone_num": "phone_hash_1001_a",
    "cif_user_id": "uid_1001",
    "device_no": "device_1001_a",
    "remote_ip": "10.12.1.8",
    "td_device_id": "td_device_1001_a"
  }
}

###
# 6) /event - login (partial fields, null-equivalent omitted)
POST {{baseUrl}}/event
Content-Type: {{json}}

{
  "type": "login",
  "ts": "2025-04-02T17:21:56",
  "data": {
    "phone_num": "phone_hash_1001_a",
    "cif_user_id": "uid_1001",
    "device_no": "",
    "remote_ip": "10.12.1.8",
    "td_device_id": null
  }
}

